# Copy this file to .env and fill in real values.
# .env is gitignored — never commit credentials.

# ── API keys ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Evaluation mode ───────────────────────────────────────────────────────
# Must be "1" when running evaluation scripts.
# aerosafety.determinism.assert_eval_mode() raises if this is not set.
AEROSAFETY_EVAL_MODE=0

# ── Optional: remote model endpoints ─────────────────────────────────────
# VLLM_BASE_URL=http://localhost:8000/v1
# HF_TOKEN=hf_...

# ── Optional: experiment tracking ─────────────────────────────────────────
# WANDB_API_KEY=...
# WANDB_PROJECT=aerosafety
